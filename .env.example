# YouTube to Ebook - Environment Variables
# Copy this file to .env and fill in your keys

# YouTube Data API Key (free from Google Cloud Console)
# Get it at: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# LLM API Key
# Default config uses an OpenAI-compatible endpoint.
OPENAI_API_KEY=your_openai_or_compatible_api_key_here

# Optional provider-specific keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Supadata API Key (for transcript fetching)
# Get it at: https://supadata.ai/
SUPADATA_API_KEY=your_supadata_api_key_here

# Gmail credentials (optional - for email delivery)
# Create an App Password at: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=your_app_password_here
